<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/family_background_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6"
    tools:context=".FamilyBackgroundActivity">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#9333EA"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/abc_ic_ab_back_material"
        app:navigationIconTint="#FFFFFF"
        app:title="II. Family Background"
        app:titleTextColor="#FFFFFF" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/bottomButtons"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Spouse's Information -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cvSpouse"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SPOUSE'S INFORMATION" android:textColor="#9333EA" android:textSize="16sp" android:textStyle="bold" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="8dp" android:layout_marginBottom="16dp" android:background="#E0E0E0" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Surname" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" />
                    <EditText android:id="@+id/spouseSurname" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="4dp" android:layout_marginBottom="12dp" android:background="@drawable/bg_edittext" android:paddingHorizontal="12dp" android:textColor="#111827" android:inputType="textCapWords" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="First Name" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" />
                    <EditText android:id="@+id/spouseFirstName" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="4dp" android:layout_marginBottom="12dp" android:background="@drawable/bg_edittext" android:paddingHorizontal="12dp" android:textColor="#111827" android:inputType="textCapWords" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Middle Name" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" />
                    <EditText android:id="@+id/spouseMiddleName" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="4dp" android:layout_marginBottom="12dp" android:background="@drawable/bg_edittext" android:paddingHorizontal="12dp" android:textColor="#111827" android:inputType="textCapWords" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Name Extension (JR, SR)" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" />
                    <EditText android:id="@+id/spouseExtension" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="4dp" android:layout_marginBottom="12dp" android:background="@drawable/bg_edittext" android:paddingHorizontal="12dp" android:textColor="#111827" android:inputType="textCapWords" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Occupation" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" />
                    <EditText android:id="@+id/spouseOccupation" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="4dp" android:layout_marginBottom="12dp" android:background="@drawable/bg_edittext" android:paddingHorizontal="12dp" android:textColor="#111827" android:inputType="textCapWords" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Employer/Business Name" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" />
                    <EditText android:id="@+id/spouseEmployer" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="4dp" android:layout_marginBottom="12dp" android:background="@drawable/bg_edittext" android:paddingHorizontal="12dp" android:textColor="#111827" android:inputType="textCapWords" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Business Address" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" />
                    <EditText android:id="@+id/spouseBusinessAddress" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="4dp" android:layout_marginBottom="12dp" android:background="@drawable/bg_edittext" android:paddingHorizontal="12dp" android:textColor="#111827" android:inputType="textCapWords" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Telephone No." android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" />
                    <EditText android:id="@+id/spouseTelephone" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="4dp" android:background="@drawable/bg_edittext" android:paddingHorizontal="12dp" android:textColor="#111827" android:inputType="phone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Children Information -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CHILDREN INFORMATION" android:textColor="#9333EA" android:textSize="16sp" android:textStyle="bold" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="8dp" android:layout_marginBottom="16dp" android:background="#E0E0E0" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Name of Children (Write full name and list all)" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" />
                    <EditText android:id="@+id/childrenNames" android:layout_width="match_parent" android:layout_height="100dp" android:layout_marginTop="4dp" android:layout_marginBottom="12dp" android:background="@drawable/bg_edittext" android:gravity="top" android:padding="12dp" android:textColor="#111827" android:inputType="textMultiLine" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Date of Birth (mm/dd/yyyy)" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" />
                    <EditText android:id="@+id/childrenBirthdates" android:layout_width="match_parent" android:layout_height="100dp" android:layout_marginTop="4dp" android:background="@drawable/bg_edittext" android:gravity="top" android:padding="12dp" android:textColor="#111827" android:inputType="textMultiLine" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Father's Information -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FATHER'S INFORMATION" android:textColor="#9333EA" android:textSize="16sp" android:textStyle="bold" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="8dp" android:layout_marginBottom="16dp" android:background="#E0E0E0" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Surname *" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" />
                    <EditText android:id="@+id/fatherSurname" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="4dp" android:layout_marginBottom="12dp" android:background="@drawable/bg_edittext" android:paddingHorizontal="12dp" android:textColor="#111827" android:inputType="textCapWords" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="First Name *" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" />
                    <EditText android:id="@+id/fatherFirstName" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="4dp" android:layout_marginBottom="12dp" android:background="@drawable/bg_edittext" android:paddingHorizontal="12dp" android:textColor="#111827" android:inputType="textCapWords" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Middle Name *" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" />
                    <EditText android:id="@+id/fatherMiddleName" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="4dp" android:layout_marginBottom="12dp" android:background="@drawable/bg_edittext" android:paddingHorizontal="12dp" android:textColor="#111827" android:inputType="textCapWords" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Name Extension (JR, SR)" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" />
                    <EditText android:id="@+id/fatherExtension" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="4dp" android:background="@drawable/bg_edittext" android:paddingHorizontal="12dp" android:textColor="#111827" android:inputType="textCapWords" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Mother's Maiden Name -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MOTHER'S MAIDEN NAME" android:textColor="#9333EA" android:textSize="16sp" android:textStyle="bold" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="8dp" android:layout_marginBottom="16dp" android:background="#E0E0E0" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Surname *" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" />
                    <EditText android:id="@+id/motherSurname" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="4dp" android:layout_marginBottom="12dp" android:background="@drawable/bg_edittext" android:paddingHorizontal="12dp" android:textColor="#111827" android:inputType="textCapWords" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="First Name *" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" />
                    <EditText android:id="@+id/motherFirstName" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="4dp" android:layout_marginBottom="12dp" android:background="@drawable/bg_edittext" android:paddingHorizontal="12dp" android:textColor="#111827" android:inputType="textCapWords" />

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Middle Name *" android:textColor="#374151" android:textSize="13sp" android:textStyle="bold" />
                    <EditText android:id="@+id/motherMiddleName" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="4dp" android:background="@drawable/bg_edittext" android:paddingHorizontal="12dp" android:textColor="#111827" android:inputType="textCapWords" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Buttons -->
    <LinearLayout
        android:id="@+id/bottomButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/backButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Back"
            android:textAllCaps="false"
            android:textColor="#9333EA"
            android:textSize="16sp"
            app:cornerRadius="8dp"
            app:strokeColor="#9333EA" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/nextButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:backgroundTint="#9333EA"
            android:text="Next"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            app:cornerRadius="8dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>